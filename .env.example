# OpenJarvis Backend Environment Variables
# Copy this file to .env and fill in at least ONE API key.
#
# You only need ONE of these — the server will use whichever keys are present.

# OpenAI (GPT-4o, o3-mini, etc.)
OPENAI_API_KEY=

# Anthropic (Claude Sonnet, Opus, Haiku)
# ANTHROPIC_API_KEY=

# Google Gemini (2.5 Pro/Flash)
# GEMINI_API_KEY=

# OpenRouter (100+ models from multiple providers)
# OPENROUTER_API_KEY=
